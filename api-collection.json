{
  "info": {
    "name": "Circuit Breaker Demo API",
    "description": "API collection for testing the Circuit Breaker Pattern with Resilience4j in Spring Boot.\n\n## Test Flow\n1. Check initial state (should be CLOSED)\n2. Fetch user data (should succeed)\n3. Check actuator metrics\n4. Trip the circuit breaker by making repeated calls\n5. Verify circuit opens and fallback is returned\n6. Wait 10s for recovery\n7. Verify circuit closes again\n8. Check final metrics",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "Circuit Breaker State",
      "item": [
        {
          "name": "Get State",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/circuit-breaker/state",
              "host": ["{{baseUrl}}"],
              "path": ["api", "circuit-breaker", "state"]
            }
          },
          "response": [
            {
              "name": "CLOSED",
              "status": "OK",
              "code": 200,
              "header": [],
              "body": "CLOSED"
            },
            {
              "name": "OPEN",
              "status": "OK",
              "code": 200,
              "header": [],
              "body": "OPEN"
            },
            {
              "name": "HALF_OPEN",
              "status": "OK",
              "code": 200,
              "header": [],
              "body": "HALF_OPEN"
            }
          ]
        }
      ]
    },
    {
      "name": "User Data",
      "item": [
        {
          "name": "Get User (Success)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "1"]
            }
          },
          "response": [
            {
              "name": "Success Response",
              "status": "OK",
              "code": 200,
              "header": [],
              "body": "{\n    \"id\": \"1\",\n    \"name\": \"Leanne Graham\",\n    \"email\": \"leanne@example.com\"\n}"
            }
          ]
        },
        {
          "name": "Get User (Fallback - Circuit Open)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "1"]
            }
          },
          "response": [
            {
              "name": "Fallback Response",
              "status": "OK",
              "code": 200,
              "header": [],
              "body": "{\n    \"id\": \"1\",\n    \"name\": \"Default User\",\n    \"email\": \"default@example.com\"\n}"
            }
          ]
        },
        {
          "name": "Get User (Different ID)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/2",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "2"]
            }
          },
          "response": [
            {
              "name": "Success Response",
              "status": "OK",
              "code": 200,
              "header": [],
              "body": "{\n    \"id\": \"2\",\n    \"name\": \"Ervin Howell\",\n    \"email\": \"ervin@example.com\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Circuit Breaker Metrics",
      "item": [
        {
          "name": "Get Custom Metrics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/circuit-breaker/metrics",
              "host": ["{{baseUrl}}"],
              "path": ["api", "circuit-breaker", "metrics"]
            }
          },
          "response": [
            {
              "name": "Metrics Response",
              "status": "OK",
              "code": 200,
              "header": [],
              "body": "{\n    \"state\": \"CLOSED\",\n    \"failureRate\": -1.0,\n    \"successRate\": 101.0,\n    \"numberOfBufferedCalls\": 0,\n    \"numberOfSuccessfulCalls\": 0,\n    \"numberOfFailedCalls\": 0,\n    \"numberOfNotPermittedCalls\": 0\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Actuator",
      "item": [
        {
          "name": "Get Actuator Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/actuator/health",
              "host": ["{{baseUrl}}"],
              "path": ["actuator", "health"]
            }
          }
        },
        {
          "name": "Get Actuator Circuitbreakers",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/actuator/circuitbreakers",
              "host": ["{{baseUrl}}"],
              "path": ["actuator", "circuitbreakers"]
            }
          },
          "response": [
            {
              "name": "Circuitbreakers Response",
              "status": "OK",
              "code": 200,
              "header": [],
              "body": "{\n    \"circuitBreakers\": {\n        \"userService\": {\n            \"failureRate\": \"-1.0%\",\n            \"slowCallRate\": \"-1.0%\",\n            \"failureRateThreshold\": \"50.0%\",\n            \"slowCallRateThreshold\": \"100.0%\",\n            \"bufferedCalls\": 0,\n            \"failedCalls\": 0,\n            \"slowCalls\": 0,\n            \"slowFailedCalls\": 0,\n            \"notPermittedCalls\": 0,\n            \"state\": \"CLOSED\"\n        }\n    }\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Test Flow: Trip Circuit Breaker",
      "item": [
        {
          "name": "1. Check Initial State",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Initial state should be CLOSED', function() {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(pm.response.text()).to.equal('CLOSED');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/circuit-breaker/state",
              "host": ["{{baseUrl}}"],
              "path": ["api", "circuit-breaker", "state"]
            }
          }
        },
        {
          "name": "2. Fetch User Data",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Response should contain user data', function() {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('id');",
                  "    pm.expect(json).to.have.property('name');",
                  "    pm.expect(json).to.have.property('email');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "1"]
            }
          }
        },
        {
          "name": "3. Trip Circuit (Call 10x to trigger failures)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var state = pm.response.text();",
                  "pm.test('Circuit should eventually open', function() {",
                  "    pm.exportVariable('circuitState', state);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "1"]
            }
          },
          "response": []
        },
        {
          "name": "4. Verify Circuit is OPEN",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Circuit should be OPEN', function() {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(pm.response.text()).to.equal('OPEN');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/circuit-breaker/state",
              "host": ["{{baseUrl}}"],
              "path": ["api", "circuit-breaker", "state"]
            }
          }
        },
        {
          "name": "5. Verify Fallback Response",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Fallback should return Default User', function() {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.name).to.equal('Default User');",
                  "    pm.expect(json.email).to.equal('default@example.com');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "1"]
            }
          }
        },
        {
          "name": "6. Wait for Recovery (10s)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/circuit-breaker/state",
              "host": ["{{baseUrl}}"],
              "path": ["api", "circuit-breaker", "state"]
            }
          }
        },
        {
          "name": "7. Verify Recovery (HALF_OPEN → CLOSED)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should receive user data', function() {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.name).to.not.equal('Default User');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "1"]
            }
          }
        },
        {
          "name": "8. Check Final Circuit State",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Final state should be CLOSED', function() {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(pm.response.text()).to.equal('CLOSED');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/circuit-breaker/state",
              "host": ["{{baseUrl}}"],
              "path": ["api", "circuit-breaker", "state"]
            }
          }
        }
      ]
    }
  ]
}
